{
  "projectType": "cli-tool",
  "projectName": "Steamtools",
  "projectDescription": "A lightweight desktop GUI tool written in Rust for viewing, installing, and removing Steam Lua Manifests to manage game unlocks.",
  "theme": "palm",
  "primaryColor": "#94cb04",
  "lightColor": "#545454",
  "darkColor": null,
  "navigation": {
