      },
      {
        "group": "Using Steamtools",
        "pages": [
          "guides/manifest-management",
          "guides/installing-games",
          "guides/removing-games",
          "guides/search-and-filter"
        ]
      },
      {
        "group": "Features",
        "pages": [
